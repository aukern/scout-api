# scout-api — Environment Variables
#
# Copy this file to .env and fill in the values before running the service.
# .env is gitignored and must never be committed.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with real values
#   docker compose --profile postgres up

# ── Compose ──────────────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=scout-api
APP_PORT=8000
APP_ENV=dev

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string. When running with Docker Compose, the
# postgres service is configured via POSTGRES_* variables below.
# For an external managed DB (Neon, Supabase, RDS): set DATABASE_URL directly.
#
DATABASE_URL=postgresql://appuser:changeme@localhost:5432/appdb
POSTGRES_DB=appdb
POSTGRES_USER=appuser
POSTGRES_PASSWORD=changeme      # Required. Change before deploying.

# ── Tests ────────────────────────────────────────────────────────────────────
# Set to a separate test database to run integration tests.
TEST_DATABASE_URL=postgresql://appuser:changeme@localhost:5432/appdb_test

# ── Application ──────────────────────────────────────────────────────────────
# LOG_LEVEL: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
MAX_CONNECTIONS=10
APP_VERSION=0.1.0
GIT_SHA=dev

# ── Object Storage (S3) ──────────────────────────────────────────────────────
# Required for file upload ingest (POST /sources/file).
# For local development, use localstack: docker compose --profile localstack up
#
S3_BUCKET_NAME=scout-api-sources
S3_REGION=us-east-1
# S3_ENDPOINT_URL=http://localhost:4566    # Uncomment for localstack
AWS_ACCESS_KEY_ID=                        # Required. Use IRSA role in production.
AWS_SECRET_ACCESS_KEY=                    # Required. Use IRSA role in production.

# ── Background Jobs (arq + Redis) ────────────────────────────────────────────
# Required for source processing (POST /sources/url and /sources/file enqueue a job).
# For local development: docker compose --profile redis up
#
REDIS_URL=redis://localhost:6379
ARQ_CONCURRENCY=10

# ── Embedding Model (arq worker — slice 20) ──────────────────────────────────
# LiteLLM model string for chunk embedding. The worker probes this model at startup
# to determine the vector dimension. The dimension MUST match the chunks.embedding
# column in Postgres (set via migration 003_processing_columns.sql).
#
# Available model strings:
#   text-embedding-ada-002        → 1536-dim (OpenAI, requires OPENAI_API_KEY)
#   text-embedding-3-small        → 1536-dim (OpenAI, reducible)
#   text-embedding-3-large        → 3072-dim (OpenAI, reducible)
#   ollama/nomic-embed-text       →  768-dim (local, requires OLLAMA_API_BASE)
#   ollama/mxbai-embed-large      → 1024-dim (local, requires OLLAMA_API_BASE)
#
# If you switch models: drop + recreate chunks.embedding with the new dimension
# (see migrations/003_processing_columns.sql). Chunks are derived data and can
# always be regenerated by re-processing sources.
#
EMBEDDING_MODEL=text-embedding-ada-002
OPENAI_API_KEY=                           # Required when using OpenAI models.
OLLAMA_API_BASE=                          # e.g. http://localhost:11434 for local Ollama.

# ── Chunking Parameters ───────────────────────────────────────────────────────
# Token-aware sliding-window chunking (tiktoken). Defaults are sane for most models.
# Increase CHUNK_OVERLAP_TOKENS for better context preservation at boundaries.
#
CHUNK_TOKEN_SIZE=512
CHUNK_OVERLAP_TOKENS=64

# ── Semantic Search (slice 23) ────────────────────────────────────────────────
# Cache TTL for search results. Identical queries are served from Redis for this
# many seconds. Invalidated immediately when a source transitions to 'ready'.
# Default: 300 (5 minutes). Set lower for faster staleness in development.
#
SEARCH_CACHE_TTL_SECONDS=300
