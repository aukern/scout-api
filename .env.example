# scout-api — Environment Variables
#
# Copy this file to .env and fill in the values before running the service.
# .env is gitignored and must never be committed.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with real values
#   docker compose --profile postgres up

# ── Compose ──────────────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=scout-api
APP_PORT=8000
APP_ENV=dev

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string. When running with Docker Compose, the
# postgres service is configured via POSTGRES_* variables below.
# For an external managed DB (Neon, Supabase, RDS): set DATABASE_URL directly.
#
DATABASE_URL=postgresql://appuser:changeme@localhost:5432/appdb
POSTGRES_DB=appdb
POSTGRES_USER=appuser
POSTGRES_PASSWORD=changeme      # Required. Change before deploying.

# ── Tests ────────────────────────────────────────────────────────────────────
# Set to a separate test database to run integration tests.
TEST_DATABASE_URL=postgresql://appuser:changeme@localhost:5432/appdb_test

# ── Application ──────────────────────────────────────────────────────────────
# LOG_LEVEL: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
MAX_CONNECTIONS=10
APP_VERSION=0.1.0
GIT_SHA=dev

# ── Object Storage (S3) ──────────────────────────────────────────────────────
# Required for file upload ingest (POST /sources/file).
# For local development, use localstack: docker compose --profile localstack up
#
S3_BUCKET_NAME=scout-api-sources
S3_REGION=us-east-1
# S3_ENDPOINT_URL=http://localhost:4566    # Uncomment for localstack
AWS_ACCESS_KEY_ID=                        # Required. Use IRSA role in production.
AWS_SECRET_ACCESS_KEY=                    # Required. Use IRSA role in production.

# ── Background Jobs (arq + Redis) ────────────────────────────────────────────
# Required for source processing (POST /sources/url and /sources/file enqueue a job).
# For local development: docker compose --profile redis up
#
REDIS_URL=redis://localhost:6379
ARQ_CONCURRENCY=10
